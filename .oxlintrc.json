{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "import", "oxc", "promise"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "typescript/promise-function-async": "error"
  },
  "env": {
    "es2024": true,
    "browser": true,
    "node": true
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    ".pnpm-store/**",
    "pnpm-lock.yaml",
    ".agents/**"
  ],
  "options": {
    "denyWarnings": true,
    "reportUnusedDisableDirectives": "error",
    "typeAware": true
  }
}
