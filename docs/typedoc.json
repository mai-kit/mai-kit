{
  "$schema": "https://typedoc.org/schema.json",
  "name": "mai-kit API",
  "lang": "zh",
  "locales": {
    "zh": {
      "tag_examples": "示例",
      "theme_default_value": "默认值",
      "theme_default_type": "默认类型",
      "theme_description": "描述",
      "theme_event": "事件",
      "theme_re_exports": "重新导出",
      "theme_renames_and_re_exports": "重命名并重新导出",
      "theme_extends": "继承",
      "theme_extended_by": "派生类",
      "theme_implemented_by": "实现类",
      "theme_implementation_of": "接口",
      "theme_inherited_from": "继承自",
      "theme_overrides": "重写",
      "theme_globals": "全局变量",
      "theme_member": "成员",
      "theme_member_plural": "成员",
      "theme_modifier": "修饰符",
      "theme_name": "名称",
      "theme_package": "包",
      "theme_packages": "包",
      "theme_type": "类型",
      "theme_union_members": "联合成员",
      "theme_value": "值",
      "theme_version": "版本"
    }
  },
  "entryPoints": ["../packages/*"],
  "entryPointStrategy": "packages",
  "packageOptions": {
    "entryPoints": ["src/index.ts"],
    "readme": "none",
    "disableSources": false,
    "disableGit": true,
    "gitRevision": "main",
    "sourceLinkTemplate": "https://github.com/mai-kit/mai-kit/blob/{gitRevision}/{path}#L{line}",
    "cascadedModifierTags": []
  },
  "plugin": ["typedoc-plugin-markdown", "typedoc-vitepress-theme", "./typedoc-plugin-api.js"],
  "out": "./api",
  "readme": "none",
  "disableSources": false,
  "disableGit": true,
  "gitRevision": "main",
  "sourceLinkTemplate": "https://github.com/mai-kit/mai-kit/blob/{gitRevision}/{path}#L{line}",
  "cascadedModifierTags": [],
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "excludeReferences": true,
  "exclude": ["**/node_modules/**", "**/dist/**", "**/tests/**"],
  "treatWarningsAsErrors": true,
  "validation": {
    "notExported": true,
    "invalidLink": true,
    "invalidPath": true,
    "notDocumented": true
  },
  "requiredToBeDocumented": ["Enum", "Function", "Class", "Interface", "TypeAlias"],
  "packagesRequiringDocumentation": [
    "@mai-kit/assets",
    "@mai-kit/analysis",
    "@mai-kit/database",
    "@mai-kit/draw",
    "@mai-kit/judgement-inference",
    "@mai-kit/judgement-solver",
    "@mai-kit/prober",
    "@mai-kit/shared",
    "@mai-kit/utils"
  ],
  "defaultCategory": "其他",
  "categoryOrder": [
    "接口与模型",
    "绘制接口",
    "B50 分析",
    "升分分析",
    "快照对比",
    "Rating 构成",
    "常用公式",
    "Rating 与评级",
    "DX 分",
    "判定计算",
    "判定求解",
    "判定反推",
    "谱面索引",
    "领域类型",
    "HTTP 工具",
    "徽章",
    "字体",
    "栅格化",
    "LXNS 适配",
    "Diving-Fish 适配",
    "缓存",
    "错误",
    "布局与格式化",
    "*"
  ],
  "includeHierarchySummary": false,
  "externalSymbolLinkMappings": {
    "@mai-kit/shared": {
      "RateType": "/api/@mai-kit/shared/type-aliases/RateType",
      "SongType": "/api/@mai-kit/shared/type-aliases/SongType",
      "FCType": "/api/@mai-kit/shared/type-aliases/FCType",
      "FSType": "/api/@mai-kit/shared/type-aliases/FSType",
      "LevelIndex": "/api/@mai-kit/shared/enumerations/LevelIndex",
      "Collection": "/api/@mai-kit/shared/interfaces/Collection",
      "CollectionType": "/api/@mai-kit/shared/type-aliases/CollectionType",
      "CollectionRequired": "/api/@mai-kit/shared/interfaces/CollectionRequired",
      "CollectionRequiredSong": "/api/@mai-kit/shared/interfaces/CollectionRequiredSong",
      "MaiKitError": "/api/@mai-kit/shared/classes/MaiKitError",
      "MaiKitErrorOptions": "/api/@mai-kit/shared/interfaces/MaiKitErrorOptions",
      "isMaiKitError": "/api/@mai-kit/shared/functions/isMaiKitError"
    }
  },
  "hideBreadcrumbs": true,
  "hidePageHeader": true,
  "hideGenerator": true,
  "parametersFormat": "table",
  "classPropertiesFormat": "table",
  "interfacePropertiesFormat": "table",
  "enumMembersFormat": "table",
  "typeDeclarationFormat": "table",
  "propertyMembersFormat": "table",
  "typeAliasPropertiesFormat": "table",
  "indexFormat": "table",
  "typeDeclarationVisibility": "compact",
  "expandObjects": false,
  "expandParameters": false,
  "useCodeBlocks": true,
  "sidebar": {
    "autoConfiguration": true,
    "pretty": true
  },
  "navigation": {
    "includeCategories": true,
    "includeGroups": false,
    "includeFolders": true,
    "compactFolders": true,
    "excludeReferences": true
  },
  "router": "member"
}
