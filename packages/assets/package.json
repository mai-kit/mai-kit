{
  "name": "@mai-kit/assets",
  "version": "0.1.3",
  "description": "舞萌 DX 静态资源：界面徽章、默认字体与 resvg wasm。",
  "keywords": [
    "game-assets",
    "maimai",
    "maimai-dx",
    "resvg",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mai-kit/mai-kit.git",
    "directory": "packages/assets"
  },
  "files": [
    "dist",
    "assets/fonts",
    "assets/resvg",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "pnpm --filter @mai-kit/assets... run build && pnpm run test:unit",
    "test:unit": "node --test tests/*.test.ts"
  },
  "dependencies": {
    "@mai-kit/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.13.3"
  }
}
