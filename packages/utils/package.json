{
  "name": "@mai-kit/utils",
  "version": "0.1.1",
  "description": "Rating、达成率、判定、DX 分和谱面处理等纯函数。",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mai-kit/mai-kit.git",
    "directory": "packages/utils"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./judgement": "./dist/judgement.js",
    "./song": "./dist/song.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "pnpm --filter @mai-kit/utils... run build && pnpm run test:unit",
    "test:unit": "node --test tests/*.test.ts"
  },
  "dependencies": {
    "@mai-kit/shared": "workspace:*"
  },
  "typedocOptions": {
    "entryPoints": [
      "src/index.ts",
      "src/judgement.ts",
      "src/song.ts"
    ]
  }
}
