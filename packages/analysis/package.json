{
  "name": "@mai-kit/analysis",
  "version": "0.1.0",
  "description": "Best50 重算、升分候选与成绩快照对比。",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@mai-kit/prober": "workspace:*",
    "@mai-kit/utils": "workspace:*"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "pnpm --filter @mai-kit/analysis... run build && pnpm run test:unit",
    "test:unit": "node --test tests/*.test.ts"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wsyzxjn/mai-kit.git",
    "directory": "packages/analysis"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
