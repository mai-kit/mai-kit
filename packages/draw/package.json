{
  "name": "@mai-kit/draw",
  "version": "0.2.0",
  "description": "舞萌 DX 成绩海报渲染。",
  "keywords": [
    "maimai",
    "maimai-dx",
    "poster-generator",
    "satori",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mai-kit/mai-kit.git",
    "directory": "packages/draw"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "browser": {
    "@resvg/resvg-js": false
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "pnpm --filter @mai-kit/draw... run build && pnpm run test:unit",
    "test:unit": "node --test tests/*.test.ts",
    "test:integration:lxns": "pnpm --filter @mai-kit/draw... run build && node --env-file-if-exists=../../.env --test tests/integration/lxns.test.ts"
  },
  "dependencies": {
    "@mai-kit/assets": "workspace:*",
    "@mai-kit/prober": "workspace:*",
    "@mai-kit/shared": "workspace:*",
    "@mai-kit/utils": "workspace:*",
    "@resvg/resvg-js": "^2.6.2",
    "@resvg/resvg-wasm": "^2.6.2",
    "react": "^19.1.0",
    "satori": "^0.26.0"
  },
  "devDependencies": {
    "@mai-kit/analysis": "workspace:*",
    "@mai-kit/database": "workspace:*",
    "@types/node": "^24.5.1",
    "@types/react": "^19.1.0"
  }
}
