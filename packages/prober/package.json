{
  "name": "@mai-kit/prober",
  "version": "0.3.0",
  "description": "舞萌 DX 玩家数据查询适配层，提供按令牌类型收窄的客户端接口。",
  "keywords": [
    "diving-fish",
    "lxns",
    "maimai",
    "maimai-dx",
    "score-tracker",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mai-kit/mai-kit.git",
    "directory": "packages/prober"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "pnpm --filter @mai-kit/prober... run build && pnpm run test:unit",
    "test:unit": "node --test tests/*.test.ts"
  },
  "dependencies": {
    "@mai-kit/shared": "workspace:*",
    "zod": "^4.4.3"
  }
}
