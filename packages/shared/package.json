{
  "name": "@mai-kit/shared",
  "version": "0.1.0",
  "description": "mai-kit 各包共享的错误基类、领域类型与无业务 HTTP 工具。",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "pnpm run build && pnpm run test:unit",
    "test:unit": "node --test tests/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^24.5.1"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wsyzxjn/mai-kit.git",
    "directory": "packages/shared"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
