{
  "name": "@mai-kit/shared",
  "version": "0.1.2",
  "description": "mai-kit 各包共享的错误基类、领域类型与无业务 HTTP 工具。",
  "keywords": [
    "maimai",
    "maimai-dx",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mai-kit/mai-kit.git",
    "directory": "packages/shared"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "pnpm run build && pnpm run test:unit",
    "test:unit": "node --test tests/*.test.ts"
  }
}
