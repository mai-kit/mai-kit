{
  "name": "mai-kit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "舞萌 DX TypeScript 工具集。",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm --filter './packages/*' -r run build",
    "dev": "pnpm --filter './packages/*' -r --parallel run dev",
    "typecheck": "pnpm run build && pnpm --filter './packages/*' -r run typecheck",
    "test": "pnpm run build && pnpm --filter './packages/*' -r --if-present run test:unit",
    "clean": "pnpm --filter './packages/*' -r run clean",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "oxfmt --check . && oxlint .",
    "fix": "oxfmt --write . && oxlint --fix .",
    "docs:dev": "pnpm run build && pnpm --filter mai-kit-docs dev",
    "docs:build": "pnpm run build && pnpm --filter mai-kit-docs build",
    "docs:preview": "pnpm --filter mai-kit-docs preview",
    "changeset": "changeset",
    "ci:version": "changeset version",
    "ci:publish": "pnpm build && changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wsyzxjn/mai-kit.git"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^24.5.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  }
}
